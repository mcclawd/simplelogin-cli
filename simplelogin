#!/bin/bash
# SimpleLogin CLI - Create and manage email aliases
# Usage: simplelogin [command] [options]

set -e

API_KEY="${SIMPLELOGIN_API_KEY:-}"
API_URL="https://app.simplelogin.io/api"
JSON_OUTPUT="${SIMPLELOGIN_JSON:-false}"

# Check API key
if [ -z "$API_KEY" ] && [ -f "$HOME/.openclaw/secrets/simplelogin.json" ]; then
    API_KEY=$(jq -r '.password // .api_key // empty' "$HOME/.openclaw/secrets/simplelogin.json" 2>/dev/null)
fi

if [ -z "$API_KEY" ]; then
    echo "Error: SIMPLELOGIN_API_KEY not set" >&2
    exit 1
fi

# Default mailbox configuration
DEFAULT_MAILBOX_ID="${SIMPLELOGIN_MAILBOX_ID:-}"  # Will auto-select first if not set

# Output helper
output() {
    if [ "$JSON_OUTPUT" = "true" ]; then
        echo "$1" | jq '.'
    else
        echo "$1"
    fi
}

# Helper functions
api_call() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"
    
    if [ -n "$data" ]; then
        curl -s -H "Authentication: $API_KEY" -H "Content-Type: application/json" -X "$method" "${API_URL}${endpoint}" -d "$data"
    else
        curl -s -H "Authentication: $API_KEY" -H "Content-Type: application/json" -X "$method" "${API_URL}${endpoint}"
    fi
}

output_json() {
    if [ "$JSON_OUTPUT" = "true" ]; then
        cat
    else
        jq -r '.email // .aliases[0].email // .alias // empty' 2>/dev/null || cat
    fi
}

# Commands
cmd_create() {
    local prefix=""
    local note=""
    local for_host=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --note|-n) note="$2"; shift 2 ;;
            --for|-f) for_host="$2"; shift 2 ;;
            --*) shift ;;
            *) prefix="$1"; shift ;;
        esac
    done
    
    # Auto-generate prefix if --for is provided
    if [ -n "$for_host" ] && [ -z "$prefix" ]; then
        prefix=$(echo "$for_host" | sed 's/[^a-zA-Z0-9]/-/g' | tr '[:upper:]' '[:lower:]')
    fi
    
    local json_data="{\"name\": \"${prefix}\""
    if [ -n "$note" ]; then
        json_data="${json_data}, \"note\": \"${note}\""
    fi
    json_data="${json_data}}"
    
    api_call POST "/alias/custom/new" "$json_data" | output_json
}

cmd_random() {
    local note=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --note|-n) note="$2"; shift 2 ;;
            *) shift ;;
        esac
    done
    
    local json_data="{}"
    if [ -n "$note" ]; then
        json_data="{\"note\": \"${note}\"}"
    fi
    
    api_call POST "/alias/random/new" "$json_data" | output_json
}

cmd_list() {
    api_call GET "/aliases?page_id=0" | jq '.aliases | .[] | .email' -r 2>/dev/null | head -20
}

cmd_disable() {
    local email="$1"
    local alias_id=$(api_call GET "/aliases?page_id=0" | jq -r ".aliases[] | select(.email == \"$email\") | .id")
    if [ -n "$alias_id" ]; then
        api_call POST "/aliases/${alias_id}/toggle" '{}'
        echo "Disabled: $email"
    fi
}

cmd_enable() {
    local email="$1"
    local alias_id=$(api_call GET "/aliases?page_id=0" | jq -r ".aliases[] | select(.email == \"$email\") | .id")
    if [ -n "$alias_id" ]; then
        api_call POST "/aliases/${alias_id}/toggle" '{}'
        echo "Enabled: $email"
    fi
}

cmd_contact_create() {
    local alias_email="$1"
    local contact_email="$2"
    
    if [ -z "$alias_email" ] || [ -z "$contact_email" ]; then
        echo "Usage: simplelogin contact-create <alias_email> <contact_email>" >&2
        echo "Example: simplelogin contact-create shopping@example.com support@vendor.com" >&2
        exit 1
    fi
    
    # Get alias ID from email
    local alias_id=$(api_call GET "/aliases?page_id=0" | jq -r ".aliases[] | select(.email == \"$alias_email\") | .id")
    if [ -z "$alias_id" ] || [ "$alias_id" = "null" ]; then
        echo "Error: Alias not found: $alias_email" >&2
        exit 1
    fi
    
    # Create contact
    local response=$(api_call POST "/aliases/${alias_id}/contacts" "{\"contact\": \"${contact_email}\"}")
    
    if [ "$JSON_OUTPUT" = "true" ]; then
        echo "$response"
    else
        local reverse_alias=$(echo "$response" | jq -r '.reverse_alias_address // .reverse_alias | gsub("[<>\"]"; "")')
        local existed=$(echo "$response" | jq -r '.existed')
        
        if [ "$existed" = "true" ]; then
            echo "Contact already exists for $contact_email"
        else
            echo "Contact created for $contact_email"
        fi
        echo "Reverse alias: $reverse_alias"
        echo "Send emails to this address → forwards through $alias_email"
    fi
}

cmd_contact_list() {
    local alias_email="$1"
    
    if [ -z "$alias_email" ]; then
        echo "Usage: simplelogin contact-list <alias_email>" >&2
        exit 1
    fi
    
    local alias_id=$(api_call GET "/aliases?page_id=0" | jq -r ".aliases[] | select(.email == \"$alias_email\") | .id")
    if [ -z "$alias_id" ] || [ "$alias_id" = "null" ]; then
        echo "Error: Alias not found: $alias_email" >&2
        exit 1
    fi
    
    api_call GET "/aliases/${alias_id}/contacts?page_id=0" | jq -r '.contacts[] | "\(.contact) → \(.reverse_alias_address // .reverse_alias | gsub("[<>\"]"; ""))"' 2>/dev/null
}

cmd_validate() {
    echo "Testing SimpleLogin API connection..."
    
    # Make API call with timeout to verify credentials
    local response
    response=$(curl -s -w "\n%{http_code}" \
        -H "Authentication: $API_KEY" \
        -H "Content-Type: application/json" \
        --connect-timeout 10 \
        --max-time 30 \
        "${API_URL}/user_info" \
        2>&1)
    
    local http_code=$(echo "$response" | tail -n1)
    local body=$(echo "$response" | sed '$d')
    
    if [ "$http_code" = "200" ]; then
        local email=$(echo "$body" | jq -r '.email // empty')
        local name=$(echo "$body" | jq -r '.name // empty')
        
        if [ "$JSON_OUTPUT" = "true" ]; then
            echo "{\"status\":\"success\",\"message\":\"API key is valid\",\"user\":{\"email\":\"$email\",\"name\":\"$name\"}}"
        else
            echo "✅ Success! API key is valid."
            echo "   User: $name <$email>"
        fi
        return 0
    else
        local error_msg=$(echo "$body" | jq -r '.error // .message // "Unknown error"')
        
        if [ "$JSON_OUTPUT" = "true" ]; then
            echo "{\"status\":\"error\",\"message\":\"API authentication failed\",\"http_code\":$http_code,\"error\":\"$error_msg\"}" >&2
        else
            echo "❌ Failed to validate API key." >&2
            echo "   HTTP Status: $http_code" >&2
            echo "   Error: $error_msg" >&2
            echo "" >&2
            echo "Check that:" >&2
            echo "  - SIMPLELOGIN_API_KEY is set correctly" >&2
            echo "  - Your API key is active in SimpleLogin dashboard" >&2
            echo "  - You have network connectivity" >&2
        fi
        return 1
    fi
}

# Main
case "${1:-}" in
    create|new)
        shift
        cmd_create "$@"
        ;;
    random)
        shift
        cmd_random "$@"
        ;;
    list|ls)
        cmd_list
        ;;
    disable)
        shift
        cmd_disable "$@"
        ;;
    enable)
        shift
        cmd_enable "$@"
        ;;
    contact-create|contact)
        shift
        cmd_contact_create "$@"
        ;;
    contact-list|contacts)
        shift
        cmd_contact_list "$@"
        ;;
    validate|test-auth|verify)
        cmd_validate
        ;;
    *)
        echo "Usage: simplelogin [create|random|list|disable|enable|contact-create|contact-list|validate] [options]"
        echo ""
        echo "Commands:"
        echo "  create [prefix] [--note text] [--for hostname]  Create custom alias"
        echo "  random [--note text]                            Create random alias"
        echo "  list                                            List recent aliases"
        echo "  disable <email>                                 Disable an alias"
        echo "  enable <email>                                  Enable an alias"
        echo "  contact-create <alias> <contact>                Create contact, get reverse alias"
        echo "  contact-list <alias>                            List contacts for an alias"
        echo "  validate                                        Test API connection & verify credentials"
        echo ""
        echo "Environment:"
        echo "  SIMPLELOGIN_API_KEY    Your SimpleLogin API key"
        echo "  SIMPLELOGIN_JSON=true  Output JSON instead of plain text"
        exit 1
        ;;
esac
